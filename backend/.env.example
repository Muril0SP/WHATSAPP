PORT=3001
# PostgreSQL - use postgresql:// ou postgres://
# Local: DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp?schema=public"
# Produção: use a URL do seu provedor (ex: Coolify, Neon, Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"
SESSION_PATH=".wwebjs_auth"
STORAGE_PATH="storage"
JWT_SECRET=altere-em-producao
NODE_ENV=development
APP_URL=http://localhost:5173
# SMTP para recuperação de senha (opcional)
# SMTP_HOST=smtp.exemplo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@seusite.com
